DJANGO_SECRET_KEY=replace-with-a-long-random-value
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=
APP_ASYNC_MODE=celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
# Leave blank because Waya ignores Celery return values. Use rpc:// only if operational tooling requires it.
CELERY_RESULT_BACKEND=
CACHE_URL=redis://localhost:6379/1
WASENDER_API_BASE_URL=https://www.wasenderapi.com
WASENDER_API_KEY=replace-with-your-provider-key
WASENDER_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
WASENDER_TRIAL_MODE=true
WASENDER_SEND_INTERVAL_SECONDS=60
WASENDER_CHECK_INTERVAL_SECONDS=2
WASENDER_CHECK_CACHE_SECONDS=604800
WASENDER_MAX_CHECKS_PER_CAMPAIGN=100
WASENDER_CONNECT_TIMEOUT=5
WASENDER_READ_TIMEOUT=30
ALLOW_LIVE_WASENDER_TEST=0
CELERY_TASK_SOFT_TIME_LIMIT=90
CELERY_TASK_TIME_LIMIT=120
